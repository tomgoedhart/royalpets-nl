# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Supabase Database URL for direct connections
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI API Key (for image generation)
OPENAI_API_KEY=sk-your-openai-api-key

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Cloudflare R2 (for image storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=royalpets-images
R2_PUBLIC_URL=https://images.royalpets.nl

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@royalpets.nl

# Print Partner API (example: Print.com)
PRINT_PARTNER_API_KEY=your-print-partner-api-key
PRINT_PARTNER_API_URL=https://api.print.com/v1

# Optional: Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
